# === Production environment template ===
# Copy to .env.production (or .env on the host) and fill in real secrets.
# DO NOT commit .env.production.

# Database
# IMPORTANT: POSTGRES_PASSWORD goes inside DATABASE_URL, so it must be
# URL-safe. Use hex (no /, +, =, : characters) to avoid Prisma P1013.
#   openssl rand -hex 32
POSTGRES_USER=news
POSTGRES_PASSWORD=GENERATE_URL_SAFE_HEX_PASSWORD
POSTGRES_DB=news

# JWT (32+ chars each, generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE
JWT_REFRESH_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Click tracking HMAC
HMAC_CLICK_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE

# Public URL — must match the domain serving traffic (used for SEO + CORS)
PUBLIC_BASE_URL=https://your-domain.com

# Admin seed — consumed once by `docker compose run migrate tsx prisma/seed.ts`
# (the seed script is idempotent; re-running with the same username is a no-op).
# Change SEED_ADMIN_PASSWORD before first deploy.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SEED_ADMIN_NAME=Admin
