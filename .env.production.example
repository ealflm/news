# === Production environment template ===
# Copy to .env.production (or .env on the host) and fill in real secrets.
# DO NOT commit .env.production.

# Database
POSTGRES_USER=news
POSTGRES_PASSWORD=GENERATE_STRONG_PASSWORD
POSTGRES_DB=news

# JWT (32+ chars each, generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE
JWT_REFRESH_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Click tracking HMAC
HMAC_CLICK_SECRET=GENERATE_RANDOM_32_CHARS_OR_MORE

# Public URL — must match the domain serving traffic (used for SEO + CORS)
PUBLIC_BASE_URL=https://your-domain.com
